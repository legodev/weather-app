# Dependencias (Nunca se deben subir, Vercel las instala en la nube)
node_modules/
.pnp
.pnp.js

# Producción / Compilación (La carpeta con el código procesado)
dist/
build/

# Archivos de configuración locales y secretos (Como claves de API)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Registro de errores (Logs)
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Configuraciones de editores de código (Opcional, pero recomendado)
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# Archivos del sistema operativo
.DS_Store
Thumbs.db